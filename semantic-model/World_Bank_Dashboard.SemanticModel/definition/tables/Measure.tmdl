	measure 'Total Economies' =
			
			DISTINCTCOUNT('Fact World Bank Data'[country_code])
		formatString: 0
		lineageTag: b295b04a-ea2b-490f-958c-3c76504a751f

	measure 'Economy in Focus' =
			
			SWITCH(
			    TRUE(),
			
			    -- Country selected
			    HASONEVALUE('Dim Country'[country_name]),
			    SELECTEDVALUE('Dim Country'[country_name]),
			
			    -- Region selected
			    HASONEVALUE('Dim Country'[region]),
			    "regional",
			
			    -- Default
			    "global"
			)
		lineageTag: d38db0c3-9d21-49ce-ac6f-fd047ad64bc6

	measure 'GDP per Capita Income Group' = ```
			
			SWITCH(
			    TRUE(),
			
			    ISBLANK([GDP per Capita (PPP)]), BLANK(),
			
			    [GDP per Capita (PPP)] < 5000, "Low Income (<5k)",
			
			    [GDP per Capita (PPP)] < 10000, 
			        "Lower-Middle Income (5k–10k)",
			
			    [GDP per Capita (PPP)] < 20000, 
			        "Upper-Middle Income (10k–20k)",
			
			    [GDP per Capita (PPP)] < 40000, 
			        "High Income (20k–40k)",
			
			    [GDP per Capita (PPP)] < 60000, 
			        "Very High Income (40k–60k)",
			
			    "Advanced Economies (>60k)"
			)
			```
		lineageTag: 22151e29-f857-4080-ae56-7d5fd8cc18eb

	measure 'Population Share (% of World Population)' =
			
			DIVIDE(
			    [Total Population],
			    CALCULATE(
			        [Total Population],
			        ALL('Dim Country')
			    )
			)
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 0d966aaf-667d-40d2-9bad-e3088698d469

	measure 'GDP Share (% of Global GDP)' =
			
			DIVIDE(
			    [GDP (PPP)],
			    CALCULATE(
			        [GDP (PPP)],
			        ALL('Dim Country')
			    )
			)
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 3c167ba4-5a67-487e-a200-a171e60f9a5a

	measure 'GDP per Capita Growth Highlighted Value' =
			
			SWITCH(
			    TRUE(),
			
			    -- Returns the GDP per capita growth value only for the selected year
			    SELECTEDVALUE('Dim Year Selector'[Year]) = SELECTEDVALUE('Dim Year'[year]),
			    [GDP per Capita Growth (Annual %)],
			
			    -- Returns blank for all non-selected years
			    BLANK()
			)
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 9956f2fb-b0e9-487a-8b17-045592d35970

	measure 'GDP (PPP)' = SUM('Fact World Bank Data'[gdp])
		formatString: #,0
		lineageTag: 1fd4d921-191c-4ded-95ae-4f6428b6d479

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'World Population Display' =
			
			VAR _Population =
			    [Total Population]
			
			VAR _IsCountryFiltered =
			    HASONEVALUE('Dim Country'[country_name])
			
			VAR _DisplayValue =
			    SWITCH(
			        TRUE(),
			
			        -- Less than 100 thousand → Thousands
			        _IsCountryFiltered && _Population < 100000,
			        _Population / 1000,
			
			        -- Country selected → Millions
			        _IsCountryFiltered,
			        _Population / 1000000,
			
			        -- Global/region → Billions displayed as millions
			        (_Population / 1000000000) * 1000
			    )
			
			VAR _Suffix =
			    SWITCH(
			        TRUE(),
			
			        _IsCountryFiltered && _Population < 100000, " K",
			        " M"
			    )
			
			RETURN
			FORMAT(
			    ROUNDDOWN(_DisplayValue, 1),
			    "#,0.0"
			) & _Suffix
		lineageTag: a27c046f-9d89-4cc5-af78-9bd9f6b69a60

	measure 'Global Income Position' =
			
			VAR EconomyValue =
			    [GDP per Capita (PPP)]
			
			VAR GlobalAverage =
			    CALCULATE(
			        [GDP per Capita (PPP)],
			        ALL('Dim Country')
			    )
			
			RETURN
			SWITCH(
			    TRUE(),
			    EconomyValue >= GlobalAverage, "Above global average income",
			    "Below global average income"
			)
		lineageTag: e64ea290-bf7c-4488-82c8-90583df23ab0
		dataCategory: ImageUrl

	measure 'GDP per Capita (PPP) Trend''' =
			
			VAR _CountryToUse =
			    IF(
			        HASONEVALUE('Dim Country'[country_name]),
			        [Economy in Focus],
			        [Country with Highest GDP per Capita]
			    )
			
			RETURN
			CALCULATE(
			    [GDP per Capita (PPP)],
			
			    REMOVEFILTERS('Dim Year Selector'),
			
			    FILTER(
			        ALL('Dim Country'),
			        'Dim Country'[country_name] = _CountryToUse
			    )
			)
		lineageTag: d16d5b8a-406f-40be-bd12-3a5de8f13cc7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Year Highlighted Value' = max('Dim Year Selector'[Year])
