	measure 'GDP per Capita (PPP) Highlighted Color' =
			
			SWITCH(
			    TRUE(),
			
			    -- Selected year with negative value
			    SELECTEDVALUE('Dim Year Selector'[Year]) = SELECTEDVALUE('Dim Year'[year]) &&
			    [GDP per Capita Growth Trend] < 0,
			    "#B22222",
			
			    -- Selected year
			    SELECTEDVALUE('Dim Year Selector'[Year]) = SELECTEDVALUE('Dim Year'[year]),
			    "#118DFF",
			
			    -- Negative value not selected
			    [GDP per Capita Growth Trend] < 0,
			    "#FFB3B3",
			
			    -- Default color
			    "#CFE7FF"
			)
		lineageTag: 9a824427-d14a-4e27-a1d0-64aeeccc1de6

