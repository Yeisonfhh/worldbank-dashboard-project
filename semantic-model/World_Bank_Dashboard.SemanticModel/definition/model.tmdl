model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-PE
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Dim Country","Fact World Bank Data","Measure","Dim Country[ISO3]"]

annotation PBI_ProTooling = ["DevMode","DaxQueryView_Desktop"]

ref table 'Dim Country'
ref table 'Fact World Bank Data'
ref table Measure
ref table 'Dim Year'
ref table 'Dim Reference Year'
ref table 'Dim Country[ISO3]'

ref cultureInfo es-ES

