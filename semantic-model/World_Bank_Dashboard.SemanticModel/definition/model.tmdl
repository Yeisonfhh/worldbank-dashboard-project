model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-PE
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Dim Country","Fact World Bank Data","Measure"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Dim Country'
ref table 'Fact World Bank Data'
ref table Measure
ref table 'Dim Year'
ref table 'Dim Year Selector'

ref cultureInfo es-ES

